---
// index.astro
---
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Encuentra las mejores fechas para viajar con tu grupo de amigos." />
    <link rel="icon" href="/favicon.ico" />
    <title>Almanaque - Cuadra las fechas de tu viaje</title>
</head>
<body class="bg-slate-50 flex items-center justify-center min-h-screen p-4">
    <main class="bg-white p-6 sm:p-10 rounded-3xl shadow-2xl max-w-md w-full text-center border border-slate-100">
        <div class="mb-6 inline-flex items-center justify-center w-16 h-16 bg-blue-50 rounded-2xl">
            <span class="text-4xl" aria-hidden="true">✈️</span>
        </div>
        
        <h1 class="text-3xl font-extrabold mb-3 text-slate-800 tracking-tight">Organiza tu viaje</h1>
        <p class="text-slate-500 mb-8 leading-relaxed">Crea un grupo y comparte el enlace de invitación para encontrar las fechas que os vienen bien.</p>
        
        <form id="createGroupForm" class="space-y-4">
            <label for="groupName" class="sr-only">Nombre del viaje</label>
            <input 
                type="text" 
                id="groupName" 
                placeholder="Nombre del viaje (ej: Tailandia 2026)" 
                minlength="2"
                maxlength="80"
                autocomplete="off"
                required
                class="w-full p-4 border-2 border-slate-200 rounded-2xl outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all text-lg"
            />
            
            <button 
                type="submit"
                id="btnGo"
                class="w-full bg-blue-600 text-white font-bold py-4 rounded-2xl hover:bg-blue-700 active:scale-[0.98] transition-all shadow-lg shadow-blue-200 flex items-center justify-center gap-2"
            >
                <span id="btnText">Crear grupo</span>
                <span id="loader" aria-hidden="true" class="hidden w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
            </button>
        </form>

        <p id="formMessage" role="status" class="hidden mt-4 rounded-xl bg-rose-50 px-4 py-3 text-sm text-rose-700"></p>
        
        <p class="mt-6 text-xs text-slate-400">
            El grupo no aparece en búsquedas, pero cualquiera con el enlace podrá verlo.
        </p>
    </main>

    <script>
        import { createClient } from '@supabase/supabase-js';

        const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
        const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
        const supabase = createClient(supabaseUrl, supabaseKey);

        const form = document.getElementById('createGroupForm') as HTMLFormElement;
        const input = document.getElementById('groupName') as HTMLInputElement;
        const btn = document.getElementById('btnGo') as HTMLButtonElement;
        const btnText = document.getElementById('btnText');
        const loader = document.getElementById('loader');
        const formMessage = document.getElementById('formMessage');

        form?.addEventListener('submit', async (event) => {
            event.preventDefault();
            const name = input.value.trim().replace(/\s+/g, ' ');

            if (name.length < 2) return;

            btn.disabled = true;
            btnText!.textContent = "Creando...";
            loader?.classList.remove('hidden');
            formMessage?.classList.add('hidden');

            try {
                const accessToken = crypto.randomUUID();
                const adminToken = crypto.randomUUID();
                const { data, error } = await supabase
                    .rpc('create_planning_group', {
                        p_name: name,
                        p_access_token: accessToken,
                        p_admin_token: adminToken,
                    });

                if (error) throw error;

                if (data) {
                    window.localStorage.setItem(`almanaque-admin-${data}`, adminToken);
                    window.location.href = `/groups/${data}#key=${encodeURIComponent(accessToken)}`;
                }
            } catch (error) {
                console.error(error);
                if (formMessage) {
                    formMessage.textContent = "No se pudo crear el grupo. Inténtalo de nuevo.";
                    formMessage.classList.remove('hidden');
                }
                btn.disabled = false;
                btnText!.textContent = "Crear grupo";
                loader?.classList.add('hidden');
            }
        });
    </script>
</body>
</html>

<style is:global>
    @import "tailwindcss";
</style>
