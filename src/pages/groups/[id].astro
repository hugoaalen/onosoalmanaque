---
import GroupCalendar from '../../components/Calendar';
const { id } = Astro.params;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Cuadra fechas de vacaciones con tu grupo." />
    <title>Almanaque - Planificador de grupo</title>
  </head>
  <body class="min-h-screen bg-slate-50">
    <main class="mx-auto max-w-7xl px-3 py-6 sm:px-6 sm:py-10">
      <GroupCalendar client:load groupId={id as string} />
    </main>
  </body>
</html>

<style is:global>
  @import "tailwindcss";

  body {
    font-family: system-ui, -apple-system, sans-serif;
  }
</style>
